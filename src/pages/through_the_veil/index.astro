---
const title = "Through the Veil";
const description = "A quiet place. Not everything needs to be explained.";
---

<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />

    <style>
      body {
        margin: 0;
        background: #0a0a0a;
        color: #eaeaea;
        font-family: system-ui, -apple-system, sans-serif;
        display: flex;
        align-items: center;
        justify-content: center;
        height: 100vh;
        text-align: center;
      }

      main {
        max-width: 600px;
        padding: 2rem;
      }

      h1 {
        font-size: 2rem;
        letter-spacing: 0.05em;
        margin-bottom: 1rem;
      }

      p {
        opacity: 0.7;
        line-height: 1.6;
      }

      .button {
        display: inline-block;
        margin-top: 2.5rem;
        padding: 0.85rem 1.4rem;
        border: 1px solid #eaeaea;
        color: #eaeaea;
        text-decoration: none;
        font-weight: 600;
        letter-spacing: 0.03em;
        transition: background 0.2s ease, color 0.2s ease;
      }

      .button:hover {
        background: #eaeaea;
        color: #0a0a0a;
      }
    </style>
  </head>

  <body>
    <main>
      <h1>Through the Veil</h1>

      <p>
        You found it.<br /><br />
        Not everything is meant to be explained right away.<br /><br />
        Some things are meant to be stepped into.
      </p>

      <a
        href="https://www.amazon.com/dp/B0GCM12FFJ"
        target="_blank"
        rel="noopener noreferrer"
        class="button"
      >
        Read Free with KU or Buy on Amazon
      </a>
    </main>
  </body>
</html>
