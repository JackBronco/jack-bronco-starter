    <style>
      body {
        margin: 0;
        background: #0a0a0a;
        color: #eaeaea;
        font-family: system-ui, -apple-system, sans-serif;
        display: flex;
        align-items: center;
        justify-content: center;
        min-height: 100vh;
        text-align: center;
      }

      main {
        max-width: 600px;
        padding: 2rem;
      }

      h1 {
        font-size: 2rem;
        letter-spacing: 0.05em;
        margin-bottom: 1rem;
      }

      p {
        opacity: 0.7;
        line-height: 1.6;
      }

      .button {
        display: inline-block;
        margin-top: 2.5rem;
        padding: 0.85rem 1.4rem;
        border: 1px solid #eaeaea;
        color: #eaeaea;
        text-decoration: none;
        font-weight: 600;
        letter-spacing: 0.03em;
        transition: background 0.2s ease, color 0.2s ease;
      }

      .button:hover {
        background: #eaeaea;
        color: #0a0a0a;
      }

      .hidden {
        opacity: 0;
        transform: translateY(10px);
      }

      .show {
        opacity: 1;
        transform: translateY(0);
        transition: opacity 0.8s ease, transform 0.8s ease;
      }

      .amazon-proof {
        display: inline-flex;
        flex-direction: column;
        align-items: center;
        gap: 0.75rem;
        margin-top: 2rem;
        text-decoration: none;
        color: #eaeaea;
        max-width: 420px;
      }

      .amazon-proof img {
        width: 100%;
        height: auto;
        border: 1px solid rgba(234, 234, 234, 0.2);
        border-radius: 6px;
        opacity: 0.9;
        transition: opacity 0.2s ease, transform 0.2s ease;
      }

      .amazon-proof span {
        font-size: 0.85rem;
        opacity: 0.55;
      }

      .amazon-proof:hover img {
        opacity: 1;
        transform: translateY(-2px);
      }

      .blurb {
        display: block;
        text-align: left;
        margin: 1.5rem 0;
        white-space: pre-line;
      }

      .genre {
        margin-top: 2rem;
        font-size: 0.9rem; /* slightly larger */
        letter-spacing: 0.08em;
        text-transform: uppercase;
       }

</style>
