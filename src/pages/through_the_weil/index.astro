---
const title = "Through the Veil";
const description = "A quiet place. Not everything needs to be explained.";
---

<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <style>
      body {
        margin: 0;
        background: #0a0a0a;
        color: #eaeaea;
        font-family: system-ui, -apple-system, sans-serif;
        display: flex;
        align-items: center;
        justify-content: center;
        height: 100vh;
        text-align: center;
      }

      main {
        max-width: 600px;
        padding: 2rem;
      }

      h1 {
        font-size: 2rem;
        letter-spacing: 0.05em;
        margin-bottom: 1rem;
      }

      p {
        opacity: 0.7;
        line-height: 1.6;
      }
    </style>
  </head>

  <body>
    <main>
      <h1>Through the Veil</h1>
      <p>
        You found it.<br /><br />
        Not everything is meant to be explained right away.<br /><br />
        Some things are meant to be stepped into.
      </p>
    </main>
  </body>
</html>
